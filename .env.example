# Resta POS — Docker environment variables
# Copy to .env and adjust before first deploy:  copy .env.example .env

# SQL Server 2022 (container) — password must meet complexity rules
# Use RESTAPOS_ prefix to avoid clashing with host SQL/MSSQL_* environment variables.
RESTAPOS_MSSQL_SA_PASSWORD=RestaPos@2024!

# Host ports
WEB_PORT=8080
API_PORT=8081
SQL_PORT=1433

# API secrets (override defaults in production)
JWT_KEY=RestaPos_Docker_SigningKey_Min32Chars!
JWT_ISSUER=CustomerApi
JWT_AUDIENCE=SystemService

# Image tag for pre-built client deploy (docker-compose.client.yml)
# RESTAPOS_VERSION=latest
